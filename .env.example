# Nome do cliente desta instância (aparece na plataforma). Ex.: "MC Distribuidora".
VITE_CLIENT_NAME=

# Frentes ativas (lista separada por vírgula). Vazio = todas.
# Ex.: "financeiro"  |  "comercial,operacoes,financeiro"
VITE_FRONTS=

# White-label do ambiente interno (o LOGIN é sempre AxisGo).
VITE_CLIENT_LOGO=   # caminho/URL do logo do cliente, ex.: /clients/batux.webp
VITE_CLIENT_BRAND=  # cor de destaque do cliente em HEX, ex.: #E9622E

# Supabase — preencha para ativar o modo PRODUÇÃO (dados persistentes).
# Enquanto estiver vazio, a plataforma roda em modo DEMO (dados só no navegador).
# Encontre estes valores no painel do Supabase: Project Settings > API.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
